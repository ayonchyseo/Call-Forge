# ── CallForge AI-call backend config ────────────────────────────────────────
# Copy this to server/.env and fill in your values.

# Vapi private API key (Dashboard → API Keys). Free trial credits work for a PoC.
VAPI_API_KEY=

# A phone number ID from Vapi (Dashboard → Phone Numbers). To use your own
# Twilio number, click "Import Twilio Number" in Vapi and paste your Twilio
# SID + auth token + number — Vapi gives you a phoneNumberId to put here.
# This is the "from" number the AI calls with. Use a US/UK/AU/NZ-capable
# number for those target regions.
VAPI_PHONE_NUMBER_ID=

# Public HTTPS URL where Vapi can reach this server's webhook.
# For local testing run `ngrok http 8787` and paste the https URL here.
# Leave blank to skip the webhook (you can still see results in the Vapi dashboard).
PUBLIC_URL=

# Port for this backend (the frontend defaults to http://localhost:8787).
PORT=8787

# ── Model / voice (English defaults) ────────────────────────────────────────
# The LLM that drives the conversation.
VAPI_LLM_PROVIDER=anthropic
VAPI_LLM_MODEL=claude-3-5-sonnet-20241022

# English text-to-speech. Azure en-US voices are solid; for the most natural
# results use 11labs (set provider=11labs and VAPI_VOICE_ID to a voice id).
VAPI_VOICE_PROVIDER=azure
VAPI_VOICE_ID=en-US-JennyNeural

# English speech-to-text. Deepgram nova-2 is fast and accurate for en-US/UK/AU/NZ.
VAPI_STT_PROVIDER=deepgram
VAPI_STT_MODEL=nova-2
VAPI_STT_LANGUAGE=en
