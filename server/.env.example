# ── CallForge AI-call backend config (Twilio + OpenAI only) ──────────────────
# Copy this file to server/.env and fill in your values. Nothing else needed.

# --- OpenAI (the AI brain + voice) ---
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Twilio (the phone line) — single-operator / BYOK fallback ---
# From the Twilio Console dashboard (https://console.twilio.com). Used when a
# user hasn't entered their own Twilio keys in Settings AND platform mode
# (below) is off. Calling +1 numbers with these requires Trust Hub approval —
# see PLATFORM_TWILIO_* if you want users to skip that entirely.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio voice-capable number in E.164 format, e.g. +15551234567
TWILIO_FROM_NUMBER=

# --- Platform Twilio — "become the platform" (true plug-and-play, no user KYC) ---
# Set these to your OWN Twilio account's PRIMARY credentials (not a subaccount's
# — Console → Account → API keys & tokens) and complete Trust Hub's Primary
# Customer Profile on it ONCE. CallForge then auto-creates an isolated Twilio
# *subaccount + phone number* for every approved user — they sign up, get
# approved, and can call immediately with zero Twilio account of their own.
# Subaccounts inherit the parent's verified identity (share the Customer
# Profile with subaccounts in Trust Hub — a one-time setup step), so their +1
# calls aren't blocked by error 21216. You carry the Twilio cost (~$1-2/mo per
# number + per-minute usage) — meter/bill your users for it on your side.
# Leave both blank to keep running in pure BYOK mode (nothing else changes).
PLATFORM_TWILIO_SID=
PLATFORM_TWILIO_TOKEN=
# Country to buy numbers in (ISO 2-letter, default US) and an optional area
# code to prefer, e.g. 415. If that area code has no numbers left, provisioning
# fails for that user — retry from the admin panel after changing/clearing this.
PLATFORM_NUMBER_COUNTRY=US
PLATFORM_NUMBER_AREA_CODE=

# --- Public URL so Twilio can stream audio to this server ---
# Twilio must reach your machine over the internet. For local testing run:
#     ngrok http 8787
# then paste the https URL it prints here (no trailing slash), e.g.
#     PUBLIC_URL=https://abc123.ngrok-free.app
PUBLIC_URL=

# --- Accounts & admin approval ----------------------------------------------
# Durable accounts: a Postgres connection string (Neon/Supabase/Render Postgres).
# WITHOUT this, accounts are stored in server/data/users.json, which is wiped on
# redeploy on hosts like Render. Set this for any real/production deployment.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Secret used to sign login tokens. Use a long random string in production so
# logins stay valid across restarts.
JWT_SECRET=
# Secret used to encrypt provisioned Twilio subaccount tokens at rest (only
# relevant if you set PLATFORM_TWILIO_* below). Falls back to JWT_SECRET if
# unset — but set your own long random string so it's stable across rotations.
ENCRYPTION_KEY=
# The first admin account (approves everyone else). Change the password!
# If unset, a default admin (admin@callforge.app / changeme123) is created and
# its credentials are printed in the server logs on first boot.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Optional tuning (lowest-cost defaults already set) ---
PORT=8787
# GA Realtime model for the live call. Leave unset to auto-try gpt-realtime →
# gpt-realtime-mini → gpt-4o-realtime-preview. Set this to pin a cheaper one.
# OPENAI_REALTIME_MODEL=gpt-realtime-mini
# Cheap model used once after the call to extract the lead/meeting info.
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
# Voice the agent speaks with: alloy, echo, shimmer, etc.
OPENAI_VOICE=alloy
# Max seconds before a call is force-ended and hung up (cost safety net).
CALL_MAX_SECONDS=300
